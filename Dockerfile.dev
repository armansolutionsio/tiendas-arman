FROM node:18-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source code
COPY . .

# Remove old build cache to ensure fresh compilation
RUN rm -rf .next

# Generate Prisma client
RUN npx prisma generate

# Expose port
EXPOSE 3000

# Start development server with file watching
CMD ["npm", "run", "dev"]