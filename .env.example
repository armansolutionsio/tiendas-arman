# Database
DATABASE_URL="postgresql://tiendas_arman_user:tiendas_arman_password_2024@localhost:5432/tiendas_arman_db"

# JWT Secret (change in production)
JWT_SECRET="super-secret-jwt-key-change-in-production"

# Node Environment
NODE_ENV="development"

# Claude API (análisis automático de productos con IA)
# Obtené tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."
# Modelo opcional. Por defecto: claude-sonnet-4-6 (~$0.01-0.02 por análisis)
# Para mejor calidad: claude-opus-4-7 (~$0.05-0.15 por análisis)
# Para menor costo: claude-haiku-4-5 (~$0.003-0.005 por análisis)
CLAUDE_MODEL="claude-sonnet-4-6"
